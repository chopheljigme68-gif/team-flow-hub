PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# Supabase (or any Postgres) connection string.
# In your Supabase project: Settings -> Database -> Connection string -> URI.
# Use the "Transaction pooler" (port 6543) for serverless hosts, or the
# direct connection (port 5432) for a long-running server like this one.
# Example for this project's Supabase instance (fill in the password):
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.rbpqgttnrfydzufqsdav.supabase.co:5432/postgres
PGSSL=true

# Used to build the link inside password-reset emails.
APP_URL=http://localhost:5173

# Optional: real SMTP delivery for password-reset emails. If left unset,
# reset links are printed to this server's console instead — fully
# functional for local testing, just not delivered to a real inbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Team Flow Hub <no-reply@yourdomain.com>

# Comma-separated emails that should always be platform admins — the only
# people who can create new workspaces (ministries/offices). Self-healing:
# add an email here and have that person log in, no manual DB work needed.
PLATFORM_ADMIN_EMAILS=daniel@flowhub.dev
